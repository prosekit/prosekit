{
  "name": "vue-example-view-adapter",
  "title": "vue-example-view-adapter",
  "type": "registry:block",
  "description": "Custom node and mark views using view adapters.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/vue-sample-define-atom-block.json",
    "https://unpkg.com/prosekit-registry/dist/r/vue-sample-sample-doc-view-adapter.json"
  ],
  "dependencies": [
    "prosekit"
  ],
  "files": [
    {
      "path": "registry/src/vue/examples/view-adapter/atom-block-view.vue",
      "type": "registry:component",
      "target": "components/editor/examples/view-adapter/atom-block-view.vue",
      "content": "<script setup lang=\"ts\">\nimport { useEditorDerivedValue, type VueNodeViewProps } from 'prosekit/vue'\n\nconst props = defineProps<VueNodeViewProps>()\n\nconst docJSON = useEditorDerivedValue((editor) => {\n  return JSON.stringify(editor.getDocJSON(), null, 2)\n})\n</script>\n\n<template>\n  <div data-atom-block=\"true\" data-atom-block-view=\"true\" class=\"bg-green-500/30\">\n    <div data-testid=\"atom-block-view-label\">Atom Block View</div>\n    <div data-testid=\"atom-block-view-pos\">{{ props.getPos() }}</div>\n    <div data-testid=\"atom-block-view-context\">\n      <pre>{{ docJSON }}</pre>\n    </div>\n  </div>\n</template>\n"
    },
    {
      "path": "registry/src/vue/examples/view-adapter/editor.vue",
      "type": "registry:component",
      "target": "components/editor/examples/view-adapter/editor.vue",
      "content": "<script setup lang=\"ts\">\nimport 'prosekit/basic/style.css'\nimport 'prosekit/basic/typography.css'\n\nimport { createEditor, type NodeJSON } from 'prosekit/core'\nimport { ProseKit } from 'prosekit/vue'\n\nimport { sampleContent } from '../../sample/sample-doc-view-adapter'\n\nimport { defineExtension } from './extension'\n\nconst props = defineProps<{\n  initialContent?: NodeJSON\n}>()\n\nconst extension = defineExtension()\nconst defaultContent = props.initialContent ?? sampleContent\nconst editor = createEditor({ extension, defaultContent })\n</script>\n\n<template>\n  <ProseKit :editor=\"editor\">\n    <div class=\"box-border h-full w-full min-h-36 overflow-y-hidden overflow-x-hidden rounded-md border border-solid border-gray-200 dark:border-gray-700 shadow-sm flex flex-col bg-white dark:bg-gray-950 text-black dark:text-white\">\n      <div class=\"relative w-full flex-1 box-border overflow-y-auto\">\n        <div :ref=\"(el) => editor.mount(el as HTMLElement | null)\" class=\"ProseMirror box-border min-h-full px-[max(4rem,calc(50%-20rem))] py-8 outline-hidden outline-0 [&_span[data-mention=user]]:text-blue-500 [&_span[data-mention=tag]]:text-violet-500\" />\n      </div>\n    </div>\n  </ProseKit>\n</template>\n"
    },
    {
      "path": "registry/src/vue/examples/view-adapter/extension.ts",
      "type": "registry:component",
      "target": "components/editor/examples/view-adapter/extension.ts",
      "content": "import { defineBasicExtension } from 'prosekit/basic'\nimport { union } from 'prosekit/core'\nimport { defineVueNodeView, type VueNodeViewComponent } from 'prosekit/vue'\n\nimport { defineAtomBlock } from '../../sample/define-atom-block'\n\nimport AtomBlockView from './atom-block-view.vue'\n\nexport function defineExtension() {\n  return union(\n    defineBasicExtension(),\n    defineAtomBlock(),\n    defineVueNodeView({\n      name: 'atomBlock',\n      component: AtomBlockView as VueNodeViewComponent,\n    }),\n  )\n}\n\nexport type EditorExtension = ReturnType<typeof defineExtension>\n"
    },
    {
      "path": "registry/src/vue/examples/view-adapter/index.ts",
      "type": "registry:component",
      "target": "components/editor/examples/view-adapter/index.ts",
      "content": "export { default as ExampleEditor } from './editor.vue'\n"
    }
  ],
  "meta": {
    "hasIcons": false,
    "hidden": true,
    "story": "view-adapter",
    "framework": "vue",
    "accumulatedFiles": [
      "registry/src/vue/examples/view-adapter/atom-block-view.vue",
      "registry/src/vue/examples/view-adapter/editor.vue",
      "registry/src/vue/examples/view-adapter/extension.ts",
      "registry/src/vue/examples/view-adapter/index.ts",
      "registry/src/vue/sample/define-atom-block.ts",
      "registry/src/vue/sample/sample-doc-view-adapter.ts"
    ],
    "internalDependencies": [
      "vue-sample-define-atom-block",
      "vue-sample-sample-doc-view-adapter"
    ]
  },
  "$schema": "https://ui.shadcn.com/schema/registry-item.json"
}
