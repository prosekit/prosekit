---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { exampleSidebar, exampleSidebarItems } from '../../example-data'
import {
  LinkCard,
  CardGrid,
} from '@astrojs/starlight/components'
---

<StarlightPage frontmatter={{ title: 'Examples', tableOfContents: false, pagefind: false }} sidebar={exampleSidebar}>
  <CardGrid>
    {
      exampleSidebarItems.map((item) => (
        <LinkCard title={item.label} href={item.link} />
      ))
    }
</StarlightPage>
