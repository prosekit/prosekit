{
  "name": "svelte-example-block-handle",
  "title": "svelte-example-block-handle",
  "type": "registry:block",
  "description": "A handle that appears on hover, allowing you to drag and re-order blocks.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/svelte-sample-sample-doc-block-handle.json",
