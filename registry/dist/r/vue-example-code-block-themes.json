  "type": "registry:block",
  "description": "Code block with multiple syntax highlighting themes.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/vue-sample-sample-doc-code-block.json",
    "https://unpkg.com/prosekit-registry/dist/r/vue-ui-code-block-view.json"
  ],
