{
  "name": "@prosekit/lit",
  "type": "module",
  "version": "0.6.0-beta.5",
  "private": false,
  "description": "Lit components and utilities for ProseKit",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/lit"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./autocomplete": "./src/components/autocomplete/index.ts",
    "./block-handle": "./src/components/block-handle/index.ts",
    "./drop-indicator": "./src/components/drop-indicator/index.ts",
    "./inline-popover": "./src/components/inline-popover/index.ts",
    "./menu": "./src/components/menu/index.ts",
    "./popover": "./src/components/popover/index.ts",
    "./resizable": "./src/components/resizable/index.ts",
    "./table-handle": "./src/components/table-handle/index.ts",
    "./tooltip": "./src/components/tooltip/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown"
  },
  "dependencies": {
    "@prosekit/web": "workspace:^"
  },
  "devDependencies": {
    "@prosekit/config-ts": "workspace:*",
    "@prosekit/config-tsdown": "workspace:*",
    "@prosekit/config-vitest": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./autocomplete": {
        "types": "./dist/autocomplete.d.ts",
        "default": "./dist/autocomplete.js"
      },
      "./block-handle": {
        "types": "./dist/block-handle.d.ts",
        "default": "./dist/block-handle.js"
      },
      "./drop-indicator": {
        "types": "./dist/drop-indicator.d.ts",
        "default": "./dist/drop-indicator.js"
      },
      "./inline-popover": {
        "types": "./dist/inline-popover.d.ts",
        "default": "./dist/inline-popover.js"
      },
      "./menu": {
        "types": "./dist/menu.d.ts",
        "default": "./dist/menu.js"
      },
      "./popover": {
        "types": "./dist/popover.d.ts",
        "default": "./dist/popover.js"
      },
      "./resizable": {
        "types": "./dist/resizable.d.ts",
        "default": "./dist/resizable.js"
      },
      "./table-handle": {
        "types": "./dist/table-handle.d.ts",
        "default": "./dist/table-handle.js"
      },
      "./tooltip": {
        "types": "./dist/tooltip.d.ts",
        "default": "./dist/tooltip.js"
      }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "typesVersions": {
      "*": {
        ".": [
          "./dist/index.d.ts"
        ],
        "autocomplete": [
          "./dist/autocomplete.d.ts"
        ],
        "block-handle": [
          "./dist/block-handle.d.ts"
        ],
        "drop-indicator": [
          "./dist/drop-indicator.d.ts"
        ],
        "inline-popover": [
          "./dist/inline-popover.d.ts"
        ],
        "menu": [
          "./dist/menu.d.ts"
        ],
        "popover": [
          "./dist/popover.d.ts"
        ],
        "resizable": [
          "./dist/resizable.d.ts"
        ],
        "table-handle": [
          "./dist/table-handle.d.ts"
        ],
        "tooltip": [
          "./dist/tooltip.d.ts"
        ]
      }
    }
  }
}
