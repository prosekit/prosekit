{
  "extends": "@ocavue/tsconfig/dom/root.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node"],
    "customConditions": ["prosekit-source", "import","browser", "svelte"]
  },
  "include": [
    "${configDir}/*",
    "${configDir}/*.json",
    "${configDir}/src/**/*.spec.*",
    "${configDir}/src/**/*.test.*",
    "${configDir}/src/**/testing/**/*",
    "${configDir}/test/",
    "${configDir}/scripts/"
  ]
}
