---
import type { Props } from '@astrojs/starlight/props'

import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro'
import Search from './Search.astro'
import SiteTitle from './SiteTitle.astro'
import SocialIcons from './SocialIcons.astro'
import ThemeSelect from './ThemeSelect.astro'

Astro.props.entry.data.title
---

<div class="flex items-center gap-5 h-full">
  <div
    class:list={[
      /* Prevent long titles overflowing and covering the search and menu buttons on narrow viewports. */
      'overflow-clip',
      /* Avoid clipping focus ring around link inside title wrapper. */
      'p-1 -m-1',
      'min-w-0',
      'flex',
    ]}
  >
    <SiteTitle {...Astro.props} />
  </div>
  <div class="hidden md:flex items-center gap-4 text-sm xl:gap-6 ml-4">
    <a href="/guides/example" class="transition-colors no-underline text-muted-foreground hover:text-accent-foreground font-500">Docs</a>
  </div>
  <div class="flex-1"></div>
  <div class:list={['flex', 'print:hidden md:flex-1 md:max-w-60']}>
    <Search {...Astro.props} />
  </div>
  <div class="hidden md:flex print:hidden items-center gap-4">
    <span class="h-6 w-px bg-gray-500/30 -mr-2"></span>
    <ThemeSelect {...Astro.props} />
    <span class="h-6 w-px bg-gray-500/30 -m-2"></span>
    <SocialIcons {...Astro.props} />
    <LanguageSelect {...Astro.props} />
  </div>
</div>
