{
  "name": "svelte-example-keymap",
  "title": "svelte-example-keymap",
  "type": "registry:block",
  "description": "Custom keyboard shortcuts and key bindings.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/svelte-ui-button.json"
  ],
  "dependencies": [
    "prosekit@^0.20.0-beta.4"
  ],
  "files": [
    {
      "path": "registry/src/svelte/examples/keymap/editor.svelte",
      "type": "registry:component",
      "target": "components/editor/examples/keymap/editor.svelte",
      "content": "<script lang=\"ts\">\nimport 'prosekit/basic/style.css'\nimport 'prosekit/basic/typography.css'\n\nimport { createEditor } from 'prosekit/core'\nimport { ProseKit } from 'prosekit/svelte'\n\nimport { defineExtension } from './extension'\nimport Toolbar from './toolbar.svelte'\n\nconst extension = defineExtension()\nconst editor = createEditor({ extension })\n\nlet submissions = $state<string[]>([])\n\nfunction pushSubmission(hotkey: string) {\n  const docString = JSON.stringify(editor.getDocJSON())\n  const submission = `${new Date().toISOString()}\\t${hotkey}\\n${docString}`\n  submissions = [...submissions, submission]\n}\n</script>\n\n<ProseKit {editor}>\n  <div class=\"box-border h-full w-full min-h-36 overflow-y-hidden overflow-x-hidden rounded-md border border-solid border-gray-200 dark:border-gray-700 shadow-sm flex flex-col bg-white dark:bg-gray-950 text-black dark:text-white\">\n    <Toolbar onSubmit={pushSubmission} />\n    <div class=\"relative w-full flex-1 box-border overflow-y-auto\">\n      <div {@attach editor.mount} class=\"ProseMirror box-border min-h-full px-[max(4rem,calc(50%-20rem))] py-8 outline-hidden outline-0 [&_span[data-mention=user]]:text-blue-500 [&_span[data-mention=tag]]:text-violet-500\"></div>\n    </div>\n  </div>\n  <fieldset class=\"mt-4 box-border flex max-w-full w-full overflow-x-auto border p-4 rounded-md shadow-sm min-w-0\">\n    <legend>Submit Records</legend>\n    <ol>\n      {#each submissions as submission, index (index)}\n        <li>\n          <pre>{submission}</pre>\n        </li>\n      {/each}\n    </ol>\n    {#if submissions.length === 0}\n      <div>No submissions yet</div>\n    {/if}\n  </fieldset>\n</ProseKit>\n"
    },
    {
      "path": "registry/src/svelte/examples/keymap/extension.ts",
      "type": "registry:component",
      "target": "components/editor/examples/keymap/extension.ts",
      "content": "import { defineBasicExtension } from 'prosekit/basic'\nimport { union } from 'prosekit/core'\n\nexport function defineExtension() {\n  return union(defineBasicExtension())\n}\n\nexport type EditorExtension = ReturnType<typeof defineExtension>\n"
    },
    {
      "path": "registry/src/svelte/examples/keymap/index.ts",
      "type": "registry:component",
      "target": "components/editor/examples/keymap/index.ts",
      "content": "export { default as ExampleEditor } from './editor.svelte'\n"
    },
    {
      "path": "registry/src/svelte/examples/keymap/toolbar.svelte",
      "type": "registry:component",
      "target": "components/editor/examples/keymap/toolbar.svelte",
      "content": "<script lang=\"ts\">\nimport { useKeymap } from 'prosekit/svelte'\nimport { toStore } from 'svelte/store'\n\nimport { Button } from '../../ui/button'\n\ninterface Props {\n  onSubmit: (hotkey: string) => void\n}\n\nconst props: Props = $props()\n\nlet hotkey = $state<'Shift-Enter' | 'Enter'>('Shift-Enter')\n\nconst keymap = $derived({\n  [hotkey]: () => {\n    props.onSubmit(hotkey)\n    return true\n  },\n})\n\nuseKeymap(toStore(() => keymap))\n\nfunction setHotkey(value: 'Shift-Enter' | 'Enter') {\n  hotkey = value\n}\n</script>\n\n<div class=\"z-2 box-border border-gray-200 dark:border-gray-800 border-solid border-l-0 border-r-0 border-t-0 border-b flex flex-wrap gap-1 p-2 items-center\">\n  <Button\n    pressed={hotkey === 'Shift-Enter'}\n    onClick={() => setHotkey('Shift-Enter')}\n  >\n    <span class=\"mr-1\">Submit with</span>\n    <kbd>Shift + Enter</kbd>\n  </Button>\n\n  <Button\n    pressed={hotkey === 'Enter'}\n    onClick={() => setHotkey('Enter')}\n  >\n    <span class=\"mr-1\">Submit with</span>\n    <kbd>Enter</kbd>\n  </Button>\n</div>\n"
    }
  ],
  "meta": {
    "hasIcons": false,
    "hidden": false,
    "story": "keymap",
    "framework": "svelte",
    "accumulatedFiles": [
      "registry/src/svelte/examples/keymap/editor.svelte",
