{
  "name": "@aria-ui-v2/elements",
  "type": "module",
  "version": "0.0.0",
  "description": "A set of web components for building accessible user interfaces",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "keywords": [],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "aria-ui-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./listbox": {
      "aria-ui-dev": "./src/listbox/index.ts",
      "types": "./dist/listbox/index.d.ts",
      "import": "./dist/listbox/index.js"
    },
    "./popover": {
      "aria-ui-dev": "./src/popover/index.ts",
      "types": "./dist/popover/index.d.ts",
      "import": "./dist/popover/index.js"
    },
    "./overlay": {
      "aria-ui-dev": "./src/overlay/index.ts",
      "types": "./dist/overlay/index.d.ts",
      "import": "./dist/overlay/index.js"
    },
    "./tooltip": {
      "aria-ui-dev": "./src/tooltip/index.ts",
      "types": "./dist/tooltip/index.d.ts",
      "import": "./dist/tooltip/index.js"
    },
    "./menu": {
      "aria-ui-dev": "./src/menu/index.ts",
      "types": "./dist/menu/index.d.ts",
      "import": "./dist/menu/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run ./src",
    "build": "pnpm run build:tsc",
    "build:tsc": "tsc -b"
  },
  "dependencies": {
    "@aria-ui-v2/integrations": "workspace:*",
    "@floating-ui/dom": "^1.7.6",
    "server-dom-shim": "^1.1.0"
  },
  "devDependencies": {
    "@aria-ui-v2/cli": "workspace:*",
    "@aria-ui-v2/core": "workspace:*",
    "@aria-ui-v2/utils": "workspace:*",
    "@ocavue/tsconfig": "^0.7.0",
    "@ocavue/utils": "^1.6.0",
    "@types/node": "^20.19.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/lib-dom": "npm:@types/web@^0.0.311",
    "lit-html": "^3.3.2",
    "preact": "^10.29.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@prosekit/config-vitest": "workspace:*",
    "solid-js": "^1.9.11",
    "svelte": "^5.53.12",
    "tsdown": "catalog:",
    "typescript": "^5.9.3",
    "vue": "^3.5.30",
    "vitest": "catalog:"
  }
}
