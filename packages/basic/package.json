{
  "name": "@prosekit/basic",
  "type": "module",
  "version": "0.9.0-beta.1",
  "private": false,
  "description": "A quick starter for ProseKit",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/basic"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": {
      "prosekit-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./style.css": {
      "prosekit-source": "./src/style.css",
      "default": "./dist/style.css"
    },
    "./typography.css": {
      "prosekit-source": "./src/typography.css",
      "default": "./dist/typography.css"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "sass --watch --no-source-map ./src/typography.scss ./src/typography.gen.css",
    "gen": "sass --no-source-map ./src/typography.scss ./src/typography.gen.css",
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown"
  },
  "dependencies": {
    "@prosekit/core": "workspace:^",
    "@prosekit/extensions": "workspace:^",
    "@prosekit/pm": "workspace:^"
  },
  "devDependencies": {
    "@prosekit/config-ts": "workspace:*",
    "@prosekit/config-tsdown": "workspace:*",
    "@prosekit/config-vitest": "workspace:*",
    "@types/jsdom": "^28.0.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "sass": "^1.99.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
