{
  "name": "svelte-example-hard-break",
  "title": "svelte-example-hard-break",
  "type": "registry:block",
  "description": "Example for hard line break node.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/svelte-sample-sample-doc-hard-break.json",
    "https://unpkg.com/prosekit-registry/dist/r/svelte-ui-button.json"
  ],
  "dependencies": [
    "prosekit@^0.20.0-beta.4"
  ],
  "files": [
    {
      "path": "registry/src/svelte/examples/hard-break/editor.svelte",
      "type": "registry:component",
      "target": "components/editor/examples/hard-break/editor.svelte",
      "content": "<script lang=\"ts\">\nimport 'prosekit/basic/style.css'\nimport 'prosekit/basic/typography.css'\n\nimport { createEditor, type NodeJSON } from 'prosekit/core'\nimport { ProseKit } from 'prosekit/svelte'\nimport { untrack } from 'svelte'\n\nimport { sampleContent } from '../../sample/sample-doc-hard-break'\n\nimport { defineExtension } from './extension'\nimport Toolbar from './toolbar.svelte'\n\nconst props: {\n  initialContent?: NodeJSON\n} = $props()\n\nconst extension = defineExtension()\nconst defaultContent = untrack(() => props.initialContent ?? sampleContent)\nconst editor = createEditor({ extension, defaultContent })\n</script>\n\n<ProseKit {editor}>\n  <div class=\"box-border h-full w-full min-h-36 overflow-y-hidden overflow-x-hidden rounded-md border border-solid border-gray-200 dark:border-gray-700 shadow-sm flex flex-col bg-white dark:bg-gray-950 text-black dark:text-white\">\n    <Toolbar />\n    <div class=\"relative w-full flex-1 box-border overflow-y-auto\">\n      <div {@attach editor.mount} class=\"ProseMirror box-border min-h-full px-[max(4rem,calc(50%-20rem))] py-8 outline-hidden outline-0 [&_span[data-mention=user]]:text-blue-500 [&_span[data-mention=tag]]:text-violet-500\"></div>\n    </div>\n  </div>\n</ProseKit>\n"
    },
    {
      "path": "registry/src/svelte/examples/hard-break/extension.ts",
      "type": "registry:component",
      "target": "components/editor/examples/hard-break/extension.ts",
      "content": "import { defineBaseKeymap, union } from 'prosekit/core'\nimport { defineDoc } from 'prosekit/extensions/doc'\nimport { defineHardBreak } from 'prosekit/extensions/hard-break'\nimport { defineParagraph } from 'prosekit/extensions/paragraph'\nimport { defineText } from 'prosekit/extensions/text'\n\nexport function defineExtension() {\n  return union(\n    defineBaseKeymap(),\n    defineDoc(),\n    defineText(),\n    defineParagraph(),\n    defineHardBreak(),\n  )\n}\n\nexport type EditorExtension = ReturnType<typeof defineExtension>\n"
    },
    {
      "path": "registry/src/svelte/examples/hard-break/index.ts",
      "type": "registry:component",
      "target": "components/editor/examples/hard-break/index.ts",
      "content": "export { default as ExampleEditor } from './editor.svelte'\n"
    },
    {
      "path": "registry/src/svelte/examples/hard-break/toolbar.svelte",
      "type": "registry:component",
      "target": "components/editor/examples/hard-break/toolbar.svelte",
      "content": "<script lang=\"ts\">\nimport { useEditor } from 'prosekit/svelte'\n\nimport { Button } from '../../ui/button'\n\nimport type { EditorExtension } from './extension'\n\nconst editor = useEditor<EditorExtension>({ update: true })\n</script>\n\n<div class=\"z-2 box-border border-gray-200 dark:border-gray-800 border-solid border-l-0 border-r-0 border-t-0 border-b flex flex-wrap gap-1 p-2 items-center\">\n  <Button\n    pressed={false}\n    disabled={!$editor.commands.insertHardBreak.canExec()}\n    onClick={() => $editor.commands.insertHardBreak()}\n  >\n    Insert Hard Break\n  </Button>\n</div>\n"
    }
  ],
  "meta": {
    "hasIcons": false,
    "hidden": false,
    "story": "hard-break",
    "framework": "svelte",
    "accumulatedFiles": [
      "registry/src/svelte/examples/hard-break/editor.svelte",
      "registry/src/svelte/examples/hard-break/extension.ts",
      "registry/src/svelte/examples/hard-break/index.ts",
      "registry/src/svelte/examples/hard-break/toolbar.svelte",
      "registry/src/svelte/sample/sample-doc-hard-break.ts",
      "registry/src/svelte/ui/button/button.svelte",
      "registry/src/svelte/ui/button/index.ts"
    ],
    "internalDependencies": [
      "svelte-sample-sample-doc-hard-break",
      "svelte-ui-button"
    ]
  },
  "$schema": "https://ui.shadcn.com/schema/registry-item.json"
}
