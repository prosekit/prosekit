---
import { Code } from '@astrojs/starlight/components'
import type { ComponentProps } from 'astro/types'

type CodeProps = ComponentProps<typeof Code>

interface Props {
  codes: CodeProps[]
}

const { codes } = Astro.props

const titles: string[] = codes.map((code): string => {
  let title = code.title
  if (!title) {
    throw new Error('Code block title is required')
  }
  return title
})

if (new Set(titles).size !== titles.length) {
  throw new Error('Code block titles must be unique')
}

import { Tabs, TabItem } from '@astrojs/starlight/components'
---

<div
  class="code-group-container shadow-md rounded-lg border-border border-solid border-1 overflow-hidden"
>
  <slot />
  <Tabs>
    {
      codes.map((code) => (
        <TabItem label={code.title || ''}>
          <Code {...{ ...code, title: undefined }} />
        </TabItem>
      ))
    }
  </Tabs>
</div>

<style is:global>
  .code-group-container {
    & .tablist-wrapper {
      scrollbar-width: none;

      & [role='tab'] {
        @apply font-mono text-sm pt-2 pb-1;

        &:not([aria-selected='true']) {
          @apply border-b-transparent;
        }
      }
    }
  }

  .code-group-container [role='tablist'] {
    border-bottom-color: transparent !important;
  }

  .code-group-container div[role='tabpanel'] {
    padding: 0 !important;
    margin: 0 !important;
    border-top-color: transparent !important;
  }

  .code-group-container div[role='tabpanel'] pre {
    border-color: transparent !important;
  }
</style>
