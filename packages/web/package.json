{
  "name": "@prosekit/web",
  "type": "module",
  "version": "0.8.0-beta.4",
  "private": false,
  "description": "A collection of web components for ProseKit",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/web"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./autocomplete": "./src/components/autocomplete/index.ts",
    "./block-handle": "./src/components/block-handle/index.ts",
    "./drop-indicator": "./src/components/drop-indicator/index.ts",
    "./inline-popover": "./src/components/inline-popover/index.ts",
    "./menu": "./src/components/menu/index.ts",
    "./popover": "./src/components/popover/index.ts",
    "./resizable": "./src/components/resizable/index.ts",
    "./table-handle": "./src/components/table-handle/index.ts",
    "./tooltip": "./src/components/tooltip/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown",
    "build:aria-ui": "node build.mjs"
  },
  "dependencies": {
    "@aria-ui/core": "^0.2.0",
    "@aria-ui/elements": "^0.1.8",
    "@aria-ui/utils": "^0.1.5",
    "@floating-ui/dom": "^1.7.6",
    "@ocavue/utils": "^1.6.0",
    "@prosekit/core": "workspace:^",
    "@prosekit/extensions": "workspace:^",
    "@prosekit/pm": "workspace:^",
    "prosemirror-tables": "^1.8.5"
  },
  "devDependencies": {
    "@aria-ui/cli": "^0.1.6",
    "@prosekit/config-ts": "workspace:*",
    "@prosekit/config-tsdown": "workspace:*",
    "@prosekit/config-vitest": "workspace:*",
    "tsdown": "catalog:",
    "type-fest": "^5.5.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/prosekit-web.d.ts",
        "default": "./dist/prosekit-web.js"
      },
      "./autocomplete": {
        "types": "./dist/prosekit-web-autocomplete.d.ts",
        "default": "./dist/prosekit-web-autocomplete.js"
      },
      "./block-handle": {
        "types": "./dist/prosekit-web-block-handle.d.ts",
        "default": "./dist/prosekit-web-block-handle.js"
      },
      "./drop-indicator": {
        "types": "./dist/prosekit-web-drop-indicator.d.ts",
        "default": "./dist/prosekit-web-drop-indicator.js"
      },
      "./inline-popover": {
        "types": "./dist/prosekit-web-inline-popover.d.ts",
        "default": "./dist/prosekit-web-inline-popover.js"
      },
      "./menu": {
        "types": "./dist/prosekit-web-menu.d.ts",
        "default": "./dist/prosekit-web-menu.js"
      },
      "./popover": {
        "types": "./dist/prosekit-web-popover.d.ts",
        "default": "./dist/prosekit-web-popover.js"
      },
      "./resizable": {
        "types": "./dist/prosekit-web-resizable.d.ts",
        "default": "./dist/prosekit-web-resizable.js"
      },
      "./table-handle": {
        "types": "./dist/prosekit-web-table-handle.d.ts",
        "default": "./dist/prosekit-web-table-handle.js"
      },
      "./tooltip": {
        "types": "./dist/prosekit-web-tooltip.d.ts",
        "default": "./dist/prosekit-web-tooltip.js"
      }
    },
    "dev": {},
    "main": "./dist/prosekit-web.js",
    "module": "./dist/prosekit-web.js",
    "types": "./dist/prosekit-web.d.ts",
    "typesVersions": {
      "*": {
        ".": [
          "./dist/prosekit-web.d.ts"
        ],
        "autocomplete": [
          "./dist/prosekit-web-autocomplete.d.ts"
        ],
        "block-handle": [
          "./dist/prosekit-web-block-handle.d.ts"
        ],
        "drop-indicator": [
          "./dist/prosekit-web-drop-indicator.d.ts"
        ],
        "inline-popover": [
          "./dist/prosekit-web-inline-popover.d.ts"
        ],
        "menu": [
          "./dist/prosekit-web-menu.d.ts"
        ],
        "popover": [
          "./dist/prosekit-web-popover.d.ts"
        ],
        "resizable": [
          "./dist/prosekit-web-resizable.d.ts"
        ],
        "table-handle": [
          "./dist/prosekit-web-table-handle.d.ts"
        ],
        "tooltip": [
          "./dist/prosekit-web-tooltip.d.ts"
        ]
      }
    }
  },
  "dev": {
    "entry": {
      "prosekit-web": "./src/index.ts",
      "prosekit-web-autocomplete": "./src/components/autocomplete/index.ts",
      "prosekit-web-block-handle": "./src/components/block-handle/index.ts",
      "prosekit-web-drop-indicator": "./src/components/drop-indicator/index.ts",
      "prosekit-web-inline-popover": "./src/components/inline-popover/index.ts",
      "prosekit-web-menu": "./src/components/menu/index.ts",
      "prosekit-web-popover": "./src/components/popover/index.ts",
      "prosekit-web-resizable": "./src/components/resizable/index.ts",
      "prosekit-web-table-handle": "./src/components/table-handle/index.ts",
      "prosekit-web-tooltip": "./src/components/tooltip/index.ts"
    }
  }
}
