{
  "name": "@prosekit/pm",
  "type": "module",
  "version": "0.1.15",
  "private": false,
  "description": "A re-export of ProseMirror packages",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/pm"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./commands": "./src/commands.ts",
    "./history": "./src/history.ts",
    "./inputrules": "./src/inputrules.ts",
    "./keymap": "./src/keymap.ts",
    "./model": "./src/model.ts",
    "./state": "./src/state.ts",
    "./transform": "./src/transform.ts",
    "./view": "./src/view.ts",
    "./view/style/prosemirror.css": "./src/view/style/prosemirror.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown"
  },
  "dependencies": {
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8"
  },
  "devDependencies": {
    "@prosekit/config-ts": "workspace:*",
    "@prosekit/config-tsdown": "workspace:*",
    "@prosekit/config-vitest": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./commands": {
        "types": "./dist/commands.d.ts",
        "default": "./dist/commands.js"
      },
      "./history": {
        "types": "./dist/history.d.ts",
        "default": "./dist/history.js"
      },
      "./inputrules": {
        "types": "./dist/inputrules.d.ts",
        "default": "./dist/inputrules.js"
      },
      "./keymap": {
        "types": "./dist/keymap.d.ts",
        "default": "./dist/keymap.js"
      },
      "./model": {
        "types": "./dist/model.d.ts",
        "default": "./dist/model.js"
      },
      "./state": {
        "types": "./dist/state.d.ts",
        "default": "./dist/state.js"
      },
      "./transform": {
        "types": "./dist/transform.d.ts",
        "default": "./dist/transform.js"
      },
      "./view": {
        "types": "./dist/view.d.ts",
        "default": "./dist/view.js"
      },
      "./view/style/prosemirror.css": {
        "default": "./dist/view/style/prosemirror.css"
      }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "typesVersions": {
      "*": {
        ".": [
          "./dist/index.d.ts"
        ],
        "commands": [
          "./dist/commands.d.ts"
        ],
        "history": [
          "./dist/history.d.ts"
        ],
        "inputrules": [
          "./dist/inputrules.d.ts"
        ],
        "keymap": [
          "./dist/keymap.d.ts"
        ],
        "model": [
          "./dist/model.d.ts"
        ],
        "state": [
          "./dist/state.d.ts"
        ],
        "transform": [
          "./dist/transform.d.ts"
        ],
        "view": [
          "./dist/view.d.ts"
        ]
      }
    }
  }
}
