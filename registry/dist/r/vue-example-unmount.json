      "registry/src/vue/ui/button/index.ts",
      "registry/src/vue/ui/inline-menu/index.ts",
      "registry/src/vue/ui/inline-menu/inline-menu.vue"
    ],
    "internalDependencies": [
      "vue-ui-inline-menu"
    ]
  },
  "$schema": "https://ui.shadcn.com/schema/registry-item.json"
}
