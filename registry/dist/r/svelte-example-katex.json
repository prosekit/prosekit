  "description": "Math equation rendering using the KaTeX library.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/svelte-sample-katex.json",
    "https://unpkg.com/prosekit-registry/dist/r/svelte-sample-sample-doc-tex.json"
  ],
