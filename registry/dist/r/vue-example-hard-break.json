{
  "name": "vue-example-hard-break",
  "title": "vue-example-hard-break",
  "type": "registry:block",
  "description": "Example for hard line break node.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/vue-sample-sample-doc-hard-break.json",
    "https://unpkg.com/prosekit-registry/dist/r/vue-ui-button.json"
  ],
  "dependencies": [
    "prosekit@^0.20.0-beta.4"
  ],
  "files": [
    {
      "path": "registry/src/vue/examples/hard-break/editor.vue",
      "type": "registry:component",
      "target": "components/editor/examples/hard-break/editor.vue",
      "content": "<script setup lang=\"ts\">\nimport 'prosekit/basic/style.css'\nimport 'prosekit/basic/typography.css'\n\nimport { createEditor, type NodeJSON } from 'prosekit/core'\nimport { ProseKit } from 'prosekit/vue'\n\nimport { sampleContent } from '../../sample/sample-doc-hard-break'\n\nimport { defineExtension } from './extension'\nimport Toolbar from './toolbar.vue'\n\nconst props = defineProps<{\n  initialContent?: NodeJSON\n}>()\n\nconst extension = defineExtension()\nconst defaultContent = props.initialContent ?? sampleContent\nconst editor = createEditor({ extension, defaultContent })\n</script>\n\n<template>\n  <ProseKit :editor=\"editor\">\n    <div class=\"box-border h-full w-full min-h-36 overflow-y-hidden overflow-x-hidden rounded-md border border-solid border-gray-200 dark:border-gray-700 shadow-sm flex flex-col bg-white dark:bg-gray-950 text-black dark:text-white\">\n      <Toolbar />\n      <div class=\"relative w-full flex-1 box-border overflow-y-auto\">\n        <div :ref=\"(el) => editor.mount(el as HTMLElement | null)\" class=\"ProseMirror box-border min-h-full px-[max(4rem,calc(50%-20rem))] py-8 outline-hidden outline-0 [&_span[data-mention=user]]:text-blue-500 [&_span[data-mention=tag]]:text-violet-500\" />\n      </div>\n    </div>\n  </ProseKit>\n</template>\n"
    },
    {
      "path": "registry/src/vue/examples/hard-break/extension.ts",
      "type": "registry:component",
      "target": "components/editor/examples/hard-break/extension.ts",
      "content": "import { defineBaseKeymap, union } from 'prosekit/core'\nimport { defineDoc } from 'prosekit/extensions/doc'\nimport { defineHardBreak } from 'prosekit/extensions/hard-break'\nimport { defineParagraph } from 'prosekit/extensions/paragraph'\nimport { defineText } from 'prosekit/extensions/text'\n\nexport function defineExtension() {\n  return union(\n    defineBaseKeymap(),\n    defineDoc(),\n    defineText(),\n    defineParagraph(),\n    defineHardBreak(),\n  )\n}\n\nexport type EditorExtension = ReturnType<typeof defineExtension>\n"
    },
    {
      "path": "registry/src/vue/examples/hard-break/index.ts",
      "type": "registry:component",
      "target": "components/editor/examples/hard-break/index.ts",
      "content": "export { default as ExampleEditor } from './editor.vue'\n"
    },
    {
      "path": "registry/src/vue/examples/hard-break/toolbar.vue",
      "type": "registry:component",
      "target": "components/editor/examples/hard-break/toolbar.vue",
      "content": "<script setup lang=\"ts\">\nimport { useEditor } from 'prosekit/vue'\n\nimport { Button } from '../../ui/button'\n\nimport type { EditorExtension } from './extension'\n\nconst editor = useEditor<EditorExtension>({ update: true })\n</script>\n\n<template>\n  <div class=\"z-2 box-border border-gray-200 dark:border-gray-800 border-solid border-l-0 border-r-0 border-t-0 border-b flex flex-wrap gap-1 p-2 items-center\">\n    <Button\n      :pressed=\"false\"\n      :disabled=\"!editor.commands.insertHardBreak.canExec()\"\n      @click=\"editor.commands.insertHardBreak()\"\n    >\n      Insert Hard Break\n    </Button>\n  </div>\n</template>\n"
    }
  ],
  "meta": {
    "hasIcons": false,
    "hidden": false,
    "story": "hard-break",
    "framework": "vue",
    "accumulatedFiles": [
      "registry/src/vue/examples/hard-break/editor.vue",
      "registry/src/vue/examples/hard-break/extension.ts",
      "registry/src/vue/examples/hard-break/index.ts",
      "registry/src/vue/examples/hard-break/toolbar.vue",
      "registry/src/vue/sample/sample-doc-hard-break.ts",
      "registry/src/vue/ui/button/button.vue",
      "registry/src/vue/ui/button/index.ts"
    ],
    "internalDependencies": [
      "vue-sample-sample-doc-hard-break",
      "vue-ui-button"
    ]
  },
  "$schema": "https://ui.shadcn.com/schema/registry-item.json"
}
