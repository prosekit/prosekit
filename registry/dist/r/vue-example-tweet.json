      "registry/src/vue/examples/tweet/tweet-view.vue",
      "registry/src/vue/sample/sample-doc-tweet.ts"
    ],
    "internalDependencies": [
      "vue-sample-sample-doc-tweet"
    ]
  },
  "$schema": "https://ui.shadcn.com/schema/registry-item.json"
}
