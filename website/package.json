    "loro-prosemirror": "^0.4.3",
    "preact": "^10.29.1",
    "prosekit": "workspace:*",
    "prosekit-registry": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-resolve-markdown-links": "^0.1.0",
