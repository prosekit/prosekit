{
  "name": "svelte-example-slash-menu",
  "title": "svelte-example-slash-menu",
  "type": "registry:block",
  "description": "Command menu triggered by typing slash (/).",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/svelte-ui-slash-menu.json"
  ],
  "dependencies": [
    "prosekit@^0.20.0-beta.4"
  ],
  "files": [
    {
      "path": "registry/src/svelte/examples/slash-menu/editor.svelte",
      "type": "registry:component",
      "target": "components/editor/examples/slash-menu/editor.svelte",
      "content": "<script lang=\"ts\">\nimport 'prosekit/basic/style.css'\nimport 'prosekit/basic/typography.css'\n\nimport { createEditor } from 'prosekit/core'\nimport { ProseKit } from 'prosekit/svelte'\n\nimport { SlashMenu } from '../../ui/slash-menu'\n\nimport { defineExtension } from './extension'\n\nconst extension = defineExtension()\nconst editor = createEditor({ extension })\n</script>\n\n<ProseKit {editor}>\n  <div class=\"box-border h-full w-full min-h-36 overflow-y-hidden overflow-x-hidden rounded-md border border-solid border-gray-200 dark:border-gray-700 shadow-sm flex flex-col bg-white dark:bg-gray-950 text-black dark:text-white\">\n    <div class=\"relative w-full flex-1 box-border overflow-y-auto\">\n      <div {@attach editor.mount} class=\"ProseMirror box-border min-h-full px-[max(4rem,calc(50%-20rem))] py-8 outline-hidden outline-0 [&_span[data-mention=user]]:text-blue-500 [&_span[data-mention=tag]]:text-violet-500\"></div>\n      <SlashMenu />\n    </div>\n  </div>\n</ProseKit>\n"
    },
    {
      "path": "registry/src/svelte/examples/slash-menu/extension.ts",
      "type": "registry:component",
      "target": "components/editor/examples/slash-menu/extension.ts",
      "content": "import { defineBasicExtension } from 'prosekit/basic'\nimport { union } from 'prosekit/core'\nimport { definePlaceholder } from 'prosekit/extensions/placeholder'\n\nexport function defineExtension() {\n  return union(\n    defineBasicExtension(),\n    definePlaceholder({ placeholder: 'Press / for commands...' }),\n  )\n}\n\nexport type EditorExtension = ReturnType<typeof defineExtension>\n"
    },
    {
      "path": "registry/src/svelte/examples/slash-menu/index.ts",
      "type": "registry:component",
      "target": "components/editor/examples/slash-menu/index.ts",
      "content": "export { default as ExampleEditor } from './editor.svelte'\n"
    }
  ],
  "meta": {
    "hasIcons": false,
    "hidden": false,
    "story": "slash-menu",
    "framework": "svelte",
    "accumulatedFiles": [
