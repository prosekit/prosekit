{
  "name": "vue-example-user-menu",
  "title": "vue-example-user-menu",
  "type": "registry:block",
  "description": "Autocomplete menu for @mentions and #hashtag",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/vue-sample-sample-tag-data.json",
    "https://unpkg.com/prosekit-registry/dist/r/vue-sample-sample-user-data.json",
    "https://unpkg.com/prosekit-registry/dist/r/vue-ui-tag-menu.json",
    "https://unpkg.com/prosekit-registry/dist/r/vue-ui-user-menu.json"
  ],
  "dependencies": [
    "prosekit"
  ],
  "files": [
    {
      "path": "registry/src/vue/examples/user-menu/editor.vue",
      "type": "registry:component",
      "target": "components/editor/examples/user-menu/editor.vue",
      "content": "<script setup lang=\"ts\">\nimport 'prosekit/basic/style.css'\nimport 'prosekit/basic/typography.css'\n\nimport { createEditor } from 'prosekit/core'\nimport { ProseKit } from 'prosekit/vue'\n\nimport { tags } from '../../sample/sample-tag-data'\nimport { users } from '../../sample/sample-user-data'\nimport { TagMenu } from '../../ui/tag-menu'\nimport { UserMenu } from '../../ui/user-menu'\n\nimport { defineExtension } from './extension'\n\nconst extension = defineExtension()\nconst editor = createEditor({ extension })\n</script>\n\n<template>\n  <ProseKit :editor=\"editor\">\n    <div class=\"box-border h-full w-full min-h-36 overflow-y-hidden overflow-x-hidden rounded-md border border-solid border-gray-200 dark:border-gray-700 shadow-sm flex flex-col bg-white dark:bg-gray-950 text-black dark:text-white\">\n      <div class=\"relative w-full flex-1 box-border overflow-y-auto\">\n        <div :ref=\"(el) => editor.mount(el as HTMLElement | null)\" class=\"ProseMirror box-border min-h-full px-[max(4rem,calc(50%-20rem))] py-8 outline-hidden outline-0 [&_span[data-mention=user]]:text-blue-500 [&_span[data-mention=tag]]:text-violet-500\" />\n        <UserMenu :users=\"users\" />\n        <TagMenu :tags=\"tags\" />\n      </div>\n    </div>\n  </ProseKit>\n</template>\n"
    },
    {
      "path": "registry/src/vue/examples/user-menu/extension.ts",
      "type": "registry:component",
      "target": "components/editor/examples/user-menu/extension.ts",
      "content": "import { defineBasicExtension } from 'prosekit/basic'\nimport { union } from 'prosekit/core'\nimport { defineMention } from 'prosekit/extensions/mention'\nimport { definePlaceholder } from 'prosekit/extensions/placeholder'\n\nexport function defineExtension() {\n  return union(\n    defineBasicExtension(),\n    definePlaceholder({\n      placeholder: 'Type @ to mention someone or # to tag something...',\n    }),\n    defineMention(),\n  )\n}\n\nexport type EditorExtension = ReturnType<typeof defineExtension>\n"
    },
    {
      "path": "registry/src/vue/examples/user-menu/index.ts",
      "type": "registry:component",
      "target": "components/editor/examples/user-menu/index.ts",
      "content": "export { default as ExampleEditor } from './editor.vue'\n"
    }
  ],
  "meta": {
    "hasIcons": false,
    "hidden": false,
    "story": "user-menu",
    "framework": "vue",
    "accumulatedFiles": [
      "registry/src/vue/examples/user-menu/editor.vue",
      "registry/src/vue/examples/user-menu/extension.ts",
      "registry/src/vue/examples/user-menu/index.ts",
      "registry/src/vue/sample/sample-tag-data.ts",
      "registry/src/vue/sample/sample-user-data.ts",
      "registry/src/vue/ui/tag-menu/index.ts",
      "registry/src/vue/ui/tag-menu/tag-menu.vue",
      "registry/src/vue/ui/user-menu/index.ts",
      "registry/src/vue/ui/user-menu/user-menu.vue"
    ],
    "internalDependencies": [
      "vue-sample-sample-tag-data",
      "vue-sample-sample-user-data",
      "vue-ui-tag-menu",
      "vue-ui-user-menu"
    ]
  },
  "$schema": "https://ui.shadcn.com/schema/registry-item.json"
}
