{
  "name": "vue-example-rtl",
  "title": "vue-example-rtl",
  "type": "registry:block",
  "description": "Right-to-left text direction support.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/vue-sample-sample-doc-rtl.json",
