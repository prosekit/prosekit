{
  "name": "svelte-example-link-mark-view",
  "title": "svelte-example-link-mark-view",
  "type": "registry:block",
  "description": "An example showing how to render a mark as a custom component.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/svelte-sample-sample-doc-link-mark-view.json"
  ],
  "dependencies": [
    "prosekit@^0.20.0-beta.4"
  ],
  "files": [
    {
      "path": "registry/src/svelte/examples/link-mark-view/editor.svelte",
      "type": "registry:component",
      "target": "components/editor/examples/link-mark-view/editor.svelte",
      "content": "<script lang=\"ts\">\nimport 'prosekit/basic/style.css'\nimport 'prosekit/basic/typography.css'\n\nimport { createEditor, type NodeJSON } from 'prosekit/core'\nimport { ProseKit } from 'prosekit/svelte'\nimport { untrack } from 'svelte'\n\nimport { sampleContent } from '../../sample/sample-doc-link-mark-view'\n\nimport { defineExtension } from './extension'\n\nconst props: {\n  initialContent?: NodeJSON\n} = $props()\n\nconst extension = defineExtension()\nconst defaultContent = untrack(() => props.initialContent ?? sampleContent)\nconst editor = createEditor({ extension, defaultContent })\n</script>\n\n<ProseKit {editor}>\n  <div class=\"box-border h-full w-full min-h-36 overflow-y-hidden overflow-x-hidden rounded-md border border-solid border-gray-200 dark:border-gray-700 shadow-sm flex flex-col bg-white dark:bg-gray-950 text-black dark:text-white\">\n    <div class=\"relative w-full flex-1 box-border overflow-y-auto\">\n      <div {@attach editor.mount} class=\"ProseMirror box-border min-h-full px-[max(4rem,calc(50%-20rem))] py-8 outline-hidden outline-0 [&_span[data-mention=user]]:text-blue-500 [&_span[data-mention=tag]]:text-violet-500\"></div>\n    </div>\n  </div>\n</ProseKit>\n"
    },
    {
      "path": "registry/src/svelte/examples/link-mark-view/extension.ts",
      "type": "registry:component",
      "target": "components/editor/examples/link-mark-view/extension.ts",
      "content": "import { defineBasicExtension } from 'prosekit/basic'\nimport { union } from 'prosekit/core'\nimport { defineSvelteMarkView } from 'prosekit/svelte'\n\nimport LinkView from './link-view.svelte'\n\nexport function defineExtension() {\n  return union(\n    defineBasicExtension(),\n    defineSvelteMarkView({\n      name: 'link',\n      component: LinkView,\n    }),\n  )\n}\n\nexport type EditorExtension = ReturnType<typeof defineExtension>\n"
    },
    {
      "path": "registry/src/svelte/examples/link-mark-view/index.ts",
      "type": "registry:component",
      "target": "components/editor/examples/link-mark-view/index.ts",
      "content": "export { default as ExampleEditor } from './editor.svelte'\n"
    },
    {
      "path": "registry/src/svelte/examples/link-mark-view/link-view.svelte",
      "type": "registry:component",
      "target": "components/editor/examples/link-mark-view/link-view.svelte",
      "content": "<script lang=\"ts\">\nimport type { SvelteMarkViewProps } from 'prosekit/svelte'\nimport { fromStore } from 'svelte/store'\n\nconst props: SvelteMarkViewProps = $props()\n\nconst colors = [\n  '#f06292',\n  '#ba68c8',\n  '#9575cd',\n  '#7986cb',\n  '#64b5f6',\n  '#4fc3f7',\n  '#4dd0e1',\n  '#4db6ac',\n  '#81c784',\n  '#aed581',\n  '#ffb74d',\n  '#ffa726',\n  '#ff8a65',\n  '#d4e157',\n  '#ffd54f',\n  '#ffecb3',\n]\n\nfunction pickRandomColor() {\n  return colors[Math.floor(Math.random() * colors.length)]\n}\n\nlet color = $state(colors[0])\nlet mark = $derived(fromStore(props.mark).current)\nlet href = $derived(mark.attrs.href as string)\n\n$effect(() => {\n  const interval = setInterval(() => {\n    color = pickRandomColor()\n  }, 1000)\n\n  return () => {\n    clearInterval(interval)\n  }\n})\n\nfunction bindContentRef(element: HTMLAnchorElement) {\n  props.contentRef(element)\n}\n</script>\n\n<!-- svelte-ignore a11y_consider_explicit_label -->\n<a use:bindContentRef {href} style:color={color} style:transition=\"color 1s ease-in-out\"></a>\n"
    }
  ],
  "meta": {
