  "version": "0.0.0",
  "description": "UI framework integrations for aria-ui",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    "./preact": {
      "aria-ui-dev": "./src/preact.ts",
      "types": "./dist/preact.d.ts",
      "import": "./dist/preact.js"
    },
    "./react": {
      "aria-ui-dev": "./src/react.ts",
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "typesVersions": {
