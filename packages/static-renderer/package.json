{
  "name": "@prosekit/static-renderer",
  "type": "module",
  "version": "0.0.0",
  "private": false,
  "description": "Static renderer for ProseKit - render JSON to HTML/Markdown/React without an editor instance",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/static-renderer"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror",
    "static-renderer",
    "SSR"
  ],
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./html": "./src/html.ts",
    "./markdown": "./src/markdown.ts",
    "./preact": "./src/preact.ts",
    "./react": "./src/react.ts",
    "./solid": "./src/solid.ts",
    "./svelte": "./src/svelte.ts",
    "./vue": "./src/vue.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown"
  },
  "dependencies": {
    "@prosekit/core": "workspace:^",
    "@prosekit/pm": "workspace:^"
  },
  "peerDependencies": {
    "preact": ">= 10.11.0",
    "react": ">= 18.2.0",
    "react-dom": ">= 18.2.0",
    "solid-js": ">= 1.7.0",
    "svelte": ">= 5.0.0",
    "vue": ">= 3.0.0"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@prosekit/config-ts": "workspace:*",
    "@prosekit/config-tsdown": "workspace:*",
    "@prosekit/config-vitest": "workspace:*",
    "@prosekit/extensions": "workspace:^",
    "@types/react": "^19.2.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "solid-js": "^1.9.13",
    "svelte": "^5.55.7",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "^3.5.34",
    "preact": "^10.29.2"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./html": {
        "types": "./dist/html.d.ts",
        "default": "./dist/html.js"
      },
      "./markdown": {
        "types": "./dist/markdown.d.ts",
        "default": "./dist/markdown.js"
      },
      "./preact": {
        "types": "./dist/preact.d.ts",
        "default": "./dist/preact.js"
      },
      "./react": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "./solid": {
        "types": "./dist/solid.d.ts",
        "default": "./dist/solid.js"
      },
      "./svelte": {
        "types": "./dist/svelte.d.ts",
        "default": "./dist/svelte.js"
      },
      "./vue": {
        "types": "./dist/vue.d.ts",
        "default": "./dist/vue.js"
      }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "typesVersions": {
      "*": {
        ".": ["./dist/index.d.ts"],
        "html": ["./dist/html.d.ts"],
        "markdown": ["./dist/markdown.d.ts"],
        "preact": ["./dist/preact.d.ts"],
        "react": ["./dist/react.d.ts"],
        "solid": ["./dist/solid.d.ts"],
        "svelte": ["./dist/svelte.d.ts"],
        "vue": ["./dist/vue.d.ts"]
      }
    }
  }
}
