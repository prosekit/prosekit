{
  "name": "@prosekit/core",
  "type": "module",
  "version": "0.12.0-beta.0",
  "private": false,
  "description": "Core features for ProseKit",
  "author": {
    "name": "ocavue",
    "email": "ocavue@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosekit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosekit/prosekit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/prosekit/prosekit/issues"
  },
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": {
      "prosekit-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test": {
      "prosekit-source": "./src/test/index.ts",
      "types": "./dist/test/index.d.ts",
      "default": "./dist/test/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build:tsc": "tsc -b tsconfig.json",
    "build:tsdown": "tsdown"
  },
  "dependencies": {
    "@ocavue/utils": "^1.6.0",
    "@prosekit/pm": "workspace:^",
    "orderedmap": "^2.1.1",
    "prosemirror-splittable": "^0.1.1",
    "type-fest": "^5.5.0"
  },
  "devDependencies": {
    "@prosekit/config-ts": "workspace:*",
    "@prosekit/config-tsdown": "workspace:*",
    "@prosekit/config-vitest": "workspace:*",
    "diffable-html-snapshot": "^0.2.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-commands": "^0.2.0"
  }
}
