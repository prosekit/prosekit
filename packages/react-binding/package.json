{
  "name": "@prosekit/react-binding",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "ProseKit binding for react-prosemirror",
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
