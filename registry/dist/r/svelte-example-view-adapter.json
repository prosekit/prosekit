{
  "name": "svelte-example-view-adapter",
  "title": "svelte-example-view-adapter",
  "type": "registry:block",
  "description": "Custom node and mark views using view adapters.",
  "registryDependencies": [
    "https://unpkg.com/prosekit-registry/dist/r/svelte-sample-define-atom-block.json",
    "https://unpkg.com/prosekit-registry/dist/r/svelte-sample-sample-doc-view-adapter.json"
  ],
  "dependencies": [
    "prosekit@^0.20.0-beta.4"
  ],
  "files": [
    {
      "path": "registry/src/svelte/examples/view-adapter/atom-block-view.svelte",
      "type": "registry:component",
      "target": "components/editor/examples/view-adapter/atom-block-view.svelte",
      "content": "<script lang=\"ts\">\nimport { useEditorDerivedValue, type SvelteNodeViewProps } from 'prosekit/svelte'\n\nconst props: SvelteNodeViewProps = $props()\n\nconst docJSON = useEditorDerivedValue((editor) => {\n  return JSON.stringify(editor.getDocJSON(), null, 2)\n})\n</script>\n\n<div data-atom-block=\"true\" data-atom-block-view=\"true\" class=\"bg-green-500/30\">\n  <div data-testid=\"atom-block-view-label\">Atom Block View</div>\n  <div data-testid=\"atom-block-view-pos\">{props.getPos()}</div>\n  <div data-testid=\"atom-block-view-context\">\n    <pre>{$docJSON}</pre>\n  </div>\n</div>\n"
    },
    {
      "path": "registry/src/svelte/examples/view-adapter/editor.svelte",
      "type": "registry:component",
      "target": "components/editor/examples/view-adapter/editor.svelte",
      "content": "<script lang=\"ts\">\nimport 'prosekit/basic/style.css'\nimport 'prosekit/basic/typography.css'\n\nimport { createEditor, type NodeJSON } from 'prosekit/core'\nimport { ProseKit } from 'prosekit/svelte'\nimport { untrack } from 'svelte'\n\nimport { sampleContent } from '../../sample/sample-doc-view-adapter'\n\nimport { defineExtension } from './extension'\n\nexport interface Props {\n  initialContent?: NodeJSON\n}\n\nconst props: Props = $props()\n\nconst extension = defineExtension()\nconst defaultContent = untrack(() => props.initialContent ?? sampleContent)\nconst editor = createEditor({ extension, defaultContent })\n</script>\n\n<ProseKit {editor}>\n  <div class=\"box-border h-full w-full min-h-36 overflow-y-hidden overflow-x-hidden rounded-md border border-solid border-gray-200 dark:border-gray-700 shadow-sm flex flex-col bg-white dark:bg-gray-950 text-black dark:text-white\">\n    <div class=\"relative w-full flex-1 box-border overflow-y-auto\">\n      <div {@attach editor.mount} class=\"ProseMirror box-border min-h-full px-[max(4rem,calc(50%-20rem))] py-8 outline-hidden outline-0 [&_span[data-mention=user]]:text-blue-500 [&_span[data-mention=tag]]:text-violet-500\"></div>\n    </div>\n  </div>\n</ProseKit>\n"
    },
    {
      "path": "registry/src/svelte/examples/view-adapter/extension.ts",
      "type": "registry:component",
      "target": "components/editor/examples/view-adapter/extension.ts",
      "content": "import { defineBasicExtension } from 'prosekit/basic'\nimport { union } from 'prosekit/core'\nimport { defineSvelteNodeView } from 'prosekit/svelte'\n\nimport { defineAtomBlock } from '../../sample/define-atom-block'\n\nimport AtomBlockView from './atom-block-view.svelte'\n\nexport function defineExtension() {\n  return union(\n    defineBasicExtension(),\n    defineAtomBlock(),\n    defineSvelteNodeView({\n      name: 'atomBlock',\n      component: AtomBlockView,\n    }),\n  )\n}\n\nexport type EditorExtension = ReturnType<typeof defineExtension>\n"
    },
    {
      "path": "registry/src/svelte/examples/view-adapter/index.ts",
      "type": "registry:component",
      "target": "components/editor/examples/view-adapter/index.ts",
      "content": "export { default as ExampleEditor } from './editor.svelte'\n"
    }
  ],
  "meta": {
    "hasIcons": false,
    "hidden": true,
    "story": "view-adapter",
    "framework": "svelte",
    "accumulatedFiles": [
      "registry/src/svelte/examples/view-adapter/atom-block-view.svelte",
      "registry/src/svelte/examples/view-adapter/editor.svelte",
      "registry/src/svelte/examples/view-adapter/extension.ts",
