    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ocavue/tsconfig": "^0.7.0",
    "@types/node": "^20.19.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/lib-dom": "npm:@types/web@^0.0.311",
    "lit-html": "^3.3.2",
    "preact": "^10.29.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "@prosekit/config-vitest": "workspace:*",
    "vitest": "catalog:"
