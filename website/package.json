    "@astrojs/starlight": "^0.41.3",
    "@astrojs/svelte": "^9.0.1",
    "@astrojs/vue": "^7.0.1",
    "@base-ui/react": "^1.6.0",
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@iconify-json/bxl": "^1.2.4",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.116",
    "@iconify-json/tabler": "^1.2.35",
